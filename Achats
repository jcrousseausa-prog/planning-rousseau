<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rousseau — Achats & Fournisseurs</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>

:root{
  --bg:#F5F4F0;--surface:#FFF;--surface2:#FAFAF8;
  --border:#E4E2DA;--border2:#C8C5BC;
  --text:#1C1B18;--text2:#6B6860;--text3:#A8A59E;
  --blue:#1A4F8A;--blue-bg:#EAF1FB;--blue-border:#AECDF5;
  --green:#1A6640;--green-bg:#E8F5EE;--green-border:#A3D9B8;
  --orange:#B85C0A;--orange-bg:#FDF3E8;--orange-border:#F5C98A;
  --red:#9B1C1C;--red-bg:#FDF0F0;--red-border:#F5ABAB;
  --purple:#5A2D8A;--purple-bg:#F2EDF9;--purple-border:#C9AEED;
  --teal:#0E6B6B;--teal-bg:#E6F5F5;--teal-border:#8DD4D4;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);font-size:14px;line-height:1.5;min-height:100vh}
header{background:var(--surface);border-bottom:1px solid var(--border);padding:.75rem 20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;position:sticky;top:0;z-index:50;box-shadow:0 1px 4px rgba(0,0,0,.08)}
.logo{font-size:16px;font-weight:600;letter-spacing:-.02em}
.logo em{color:var(--text3);font-style:normal;font-weight:400}
.header-right{display:flex;gap:8px;margin-left:auto;align-items:center;flex-wrap:wrap}
.rt-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.rt-label{font-size:11px;color:var(--green);font-weight:500}
.sync-pill{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:500;background:var(--green-bg);color:var(--green);border:1px solid var(--green-border);transition:all .3s}
.sync-pill.saving{background:var(--orange-bg);color:var(--orange);border-color:var(--orange-border)}
.sync-pill.error{background:var(--red-bg);color:var(--red);border-color:var(--red-border)}
.sync-dot{width:6px;height:6px;border-radius:50%;background:currentColor}
.sync-pill.saving .sync-dot{animation:blink .6s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.app-tabs{background:var(--surface);border-bottom:1px solid var(--border);padding:0 20px;display:flex;gap:0;overflow-x:auto;position:sticky;top:49px;z-index:40;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.app-tab{padding:10px 15px;border:none;background:none;cursor:pointer;font-family:inherit;font-size:13px;font-weight:500;color:var(--text2);border-bottom:2px solid transparent;margin-bottom:-1px;white-space:nowrap;transition:color .15s}
.app-tab:hover{color:var(--text)}
.app-tab.active{color:var(--blue);border-bottom-color:var(--blue)}
.notif-dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--red);margin-left:4px;vertical-align:middle}
.new-badge{display:inline-block;background:var(--green);color:#fff;font-size:8px;font-weight:700;padding:1px 5px;border-radius:8px;margin-left:4px;vertical-align:middle;text-transform:uppercase;letter-spacing:.04em}
main{padding:16px 20px;max-width:1600px;margin:0 auto}
.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:8px;margin-bottom:14px}
.metric{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:10px 14px}
.metric-k{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.metric-v{font-size:20px;font-weight:600;font-family:'DM Mono',monospace}
.metric-v.warn{color:var(--orange)}.metric-v.alert{color:var(--red)}.metric-v.ok{color:var(--green)}
.metric-sub{font-size:10px;color:var(--text3);margin-top:1px}
.toolbar{display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap}
.search-wrap{position:relative;flex:1;max-width:320px}
.search-wrap input{width:100%;padding:7px 10px 7px 32px;border:1px solid var(--border);border-radius:8px;font-family:inherit;font-size:13px;background:var(--surface);color:var(--text)}
.search-wrap input:focus{outline:none;border-color:var(--blue)}
.search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:13px;pointer-events:none}
.btn{padding:7px 13px;border:1px solid var(--border2);border-radius:8px;background:var(--surface);color:var(--text);cursor:pointer;font-family:inherit;font-size:12px;font-weight:500;transition:background .15s;white-space:nowrap}
.btn:hover{background:var(--bg)}
.btn-primary{background:var(--blue);color:#fff;border-color:var(--blue)}.btn-primary:hover{background:#153f6e}
.btn-green{background:var(--green-bg);color:var(--green);border-color:var(--green-border)}
.btn-orange{background:var(--orange-bg);color:var(--orange);border-color:var(--orange-border)}
.btn-red{background:var(--red-bg);color:var(--red);border-color:var(--red-border)}
.btn-purple{background:var(--purple-bg);color:var(--purple);border-color:var(--purple-border)}
.btn-sm{padding:3px 9px;font-size:11px;border-radius:6px}
.table-wrap{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;overflow-x:auto}
table{width:100%;border-collapse:collapse;min-width:980px}
th{background:var(--bg);font-size:10px;color:var(--text2);font-weight:600;text-transform:uppercase;letter-spacing:.06em;padding:8px 12px;text-align:left;border-bottom:1px solid var(--border);white-space:nowrap}
td{padding:7px 11px;border-bottom:1px solid var(--border);vertical-align:middle;font-size:13px}
tr:last-child td{border-bottom:none}
.row-chantier td{background:#EAF1FB;font-weight:600}
.row-chantier:hover td{background:#DDEAF8;cursor:pointer}
.row-tranche td{background:var(--surface2);padding-left:26px!important}
.row-tranche:hover td{background:#F0EFE8;cursor:pointer}
.row-phase td{background:var(--surface);padding-left:42px!important;font-size:12px}
.row-phase:hover td{background:#F5F4F0;cursor:pointer}
.row-article td{background:#FAFAF8;padding-left:58px!important;font-size:12px;color:var(--text2)}
.row-article:hover td{background:#F0EFE8}
.row-add td{background:#F8F8F5;padding-left:58px!important;border-bottom:1px solid var(--border)}
.row-add-ph td{background:#F4F4F2;padding-left:42px!important;border-bottom:1px solid var(--border)}
.row-add-tr td{background:#EEF3FB;padding-left:26px!important;border-bottom:1px solid var(--border)}
.chevron{display:inline-block;font-size:9px;color:var(--text3);margin-right:5px;transition:transform .18s;user-select:none}
.chevron.open{transform:rotate(90deg)}
.badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:6px;font-size:10px;font-weight:600;white-space:nowrap;gap:3px}
.badge-green{background:var(--green-bg);color:var(--green);border:1px solid var(--green-border)}
.badge-orange{background:var(--orange-bg);color:var(--orange);border:1px solid var(--orange-border)}
.badge-red{background:var(--red-bg);color:var(--red);border:1px solid var(--red-border)}
.badge-blue{background:var(--blue-bg);color:var(--blue);border:1px solid var(--blue-border)}
.badge-purple{background:var(--purple-bg);color:var(--purple);border:1px solid var(--purple-border)}
.badge-gray{background:var(--bg);color:var(--text2);border:1px solid var(--border)}
.badge-teal{background:var(--teal-bg);color:var(--teal);border:1px solid var(--teal-border)}
.prog{display:flex;align-items:center;gap:6px;min-width:80px}
.prog-bar{flex:1;height:5px;border-radius:3px;background:var(--border);overflow:hidden;min-width:36px}
.prog-fill{height:100%;border-radius:3px;transition:width .3s}
.prog-blue{background:var(--blue)}.prog-green{background:var(--green)}.prog-orange{background:var(--orange)}
.prog-label{font-size:11px;font-family:'DM Mono',monospace;color:var(--text2);min-width:28px}
.dp{font-size:10px;padding:2px 7px;border-radius:5px;font-family:'DM Mono',monospace;font-weight:500;white-space:nowrap}
.dp-orange{background:var(--orange-bg);color:var(--orange)}
.dp-blue{background:var(--blue-bg);color:var(--blue)}
.dp-green{background:var(--green-bg);color:var(--green)}
.dp-red{background:var(--red-bg);color:var(--red)}
.dp-purple{background:var(--purple-bg);color:var(--purple)}
.emp{font-size:10px;padding:2px 7px;border-radius:4px;background:var(--purple-bg);color:var(--purple);font-weight:700;font-family:'DM Mono',monospace;border:1px solid var(--purple-border)}
/* CDE */
.cde-list{display:flex;flex-direction:column;gap:8px}
.cde-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden}
.cde-header{display:flex;align-items:center;gap:10px;padding:11px 14px;cursor:pointer}
.cde-header:hover{background:var(--surface2)}
.cde-body{border-top:1px solid var(--border);padding:12px 14px;background:var(--surface2)}
.cde-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:10px}
.cde-meta .k{color:var(--text3);display:block;margin-bottom:2px;font-size:10px}
.cde-meta .v{font-weight:600;color:var(--text);font-size:12px}
.lignes-table{width:100%;border-collapse:collapse;font-size:12px}
.lignes-table th{background:var(--bg);padding:5px 8px;text-align:left;border-bottom:1px solid var(--border);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--text2)}
.lignes-table td{padding:5px 8px;border-bottom:1px solid var(--border)}
.lignes-table tr:last-child td{border-bottom:none}
.lignes-table td.r{text-align:right;font-family:'DM Mono',monospace}
.ecart-bad{color:var(--red);font-weight:600}.ecart-ok{color:var(--green);font-weight:600}
/* STOCK */
.stock-table{width:100%;border-collapse:collapse}
.stock-table th{background:var(--bg);font-size:10px;color:var(--text2);font-weight:600;text-transform:uppercase;letter-spacing:.06em;padding:7px 12px;text-align:left;border-bottom:1px solid var(--border);white-space:nowrap}
.stock-table td{padding:8px 12px;border-bottom:1px solid var(--border);font-size:13px;vertical-align:middle}
.stock-table tr:last-child td{border-bottom:none}
.stock-table tr:hover td{background:#FAFAF8}
.stock-table tr.sorti td{opacity:.45}
/* BL */
.bl-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:8px}
.bl-header{display:flex;align-items:center;gap:10px;padding:11px 14px;cursor:pointer}
.bl-header:hover{background:var(--surface2)}
.bl-body{border-top:1px solid var(--border);padding:14px;background:var(--surface2)}
/* CHARGE */
.charge-block{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:10px}
.charge-head{padding:10px 14px;color:#fff;font-weight:600;font-size:13px;display:flex;align-items:center;gap:10px}
.charge-week-title{padding:5px 14px;background:var(--bg);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text2);border-bottom:1px solid var(--border)}
.charge-line{display:flex;align-items:center;gap:10px;padding:8px 14px;border-bottom:1px solid var(--border)}
.charge-line:last-child{border-bottom:none}
.charge-line:hover{background:var(--bg)}
/* MODAL */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:300;align-items:center;justify-content:center;padding:16px}
.modal-bg.show{display:flex}
.modal{background:var(--surface);border-radius:14px;padding:20px;width:520px;max-width:95vw;max-height:90vh;overflow-y:auto;box-shadow:0 8px 40px rgba(0,0,0,.18)}
.modal h2{font-size:15px;font-weight:600;margin-bottom:14px}
.modal-footer{display:flex;gap:8px;justify-content:flex-end;margin-top:16px}
.field{margin-bottom:12px}
.field label{display:block;font-size:11px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px}
.field input,.field select,.field textarea{width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:8px;font-family:inherit;font-size:13px;background:var(--surface);color:var(--text)}
.field input:focus,.field select:focus{outline:none;border-color:var(--blue)}
.field-2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.field-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.info-box{background:var(--blue-bg);border:1px solid var(--blue-border);border-radius:8px;padding:9px 12px;font-size:12px;color:var(--blue);margin-bottom:10px}
.warn-box{background:var(--orange-bg);border:1px solid var(--orange-border);border-radius:8px;padding:9px 12px;font-size:12px;color:var(--orange);margin-bottom:10px}
/* BL PRINT */
.bl-print-wrap{background:#fff;border:1px solid var(--border);border-radius:8px;padding:16px;font-size:12px}
.bl-print-title{text-align:center;font-size:15px;font-weight:700;border:1px solid #888;padding:4px;margin-bottom:10px;letter-spacing:.1em}
.bl-print-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.bl-print-box{border:1px solid #888;padding:7px;font-size:11px;line-height:1.5;border-radius:3px}
.bl-print-box strong{display:block;margin-bottom:3px;font-size:10px;text-transform:uppercase;letter-spacing:.05em}
table.bl-lignes{width:100%;border-collapse:collapse;font-size:11px}
table.bl-lignes th{background:#f0f0f0;padding:4px 7px;border:1px solid #888;text-align:left;font-size:10px;text-transform:uppercase}
table.bl-lignes td{padding:4px 7px;border:1px solid #ccc;min-height:20px}
table.bl-lignes td.r{text-align:right}
.bl-sigs{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px}
.bl-sig-box{border:1px solid #888;border-radius:3px;padding:7px;min-height:55px;font-size:10px;font-weight:700}
.screen{display:none}.screen.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
.screen.active{animation:fadeIn .18s ease}
#toast{position:fixed;bottom:1.5rem;right:1.5rem;background:var(--text);color:#fff;padding:8px 16px;border-radius:8px;font-size:12px;font-weight:500;z-index:999;opacity:0;transform:translateY(10px);transition:all .25s;pointer-events:none}
#toast.show{opacity:1;transform:translateY(0)}
.toggle-check{appearance:none;width:16px;height:16px;border:1.5px solid var(--border2);border-radius:4px;cursor:pointer;position:relative;background:var(--surface);flex-shrink:0}
.toggle-check:checked{background:var(--green);border-color:var(--green)}
.toggle-check:checked::after{content:'✓';position:absolute;top:-1px;left:2px;font-size:11px;color:#fff;font-weight:700}
@media print{
  header,.app-tabs,.toolbar,#bl-actions{display:none!important}
  body{background:#fff}
}

/* ── HEURES MODULE ── */
.htab { padding:9px 16px;border:none;background:none;cursor:pointer;font-family:inherit;font-size:13px;font-weight:500;color:var(--text2);border-bottom:2px solid transparent;margin-bottom:-1px;transition:color .15s; }
.htab:hover { color:var(--text); }
.htab.active { color:var(--text);border-bottom-color:var(--text); }
.emp-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px;margin-bottom:1rem; }
.emp-card { background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px 14px;display:flex;flex-direction:column;gap:4px; }
.emp-card-name { font-size:13px;font-weight:600; }
.emp-card-meta { font-size:11px;color:var(--text2); }
.emp-badge-cdi { background:var(--green-bg);color:var(--green);border:1px solid var(--green-border);padding:1px 7px;border-radius:10px;font-size:10px;font-weight:700; }
.emp-badge-interim { background:var(--orange-bg);color:var(--orange);border:1px solid var(--orange-border);padding:1px 7px;border-radius:10px;font-size:10px;font-weight:700; }
.emp-badge-cdd { background:var(--blue-bg);color:var(--blue);border:1px solid var(--blue-border);padding:1px 7px;border-radius:10px;font-size:10px;font-weight:700; }
.planning-print { background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden; }
.planning-print th { background:#1A4F8A;color:#fff;font-size:11px;padding:8px 10px;text-align:center;border:1px solid rgba(255,255,255,.2); }
.planning-print td { padding:7px 10px;border:1px solid var(--border);font-size:12px;vertical-align:middle; }
.pp-present { background:#EAFAF1;color:#1E8449;font-weight:600;text-align:center;border-radius:4px;padding:2px 6px;font-size:11px; }
.pp-absent  { background:#FDECEA;color:#C0392B;font-weight:600;text-align:center;border-radius:4px;padding:2px 6px;font-size:11px; }
.pp-rtt    { background:#EAF2FB;color:#1A5276;font-weight:600;text-align:center;border-radius:4px;padding:2px 6px;font-size:11px; }
@media print {
  .app-tab,.htab,.btn,.toolbar,#conn-bar,header,.tabs,#jours-panel-area { display:none!important; }
  .screen { display:block!important; }
  .planning-print { border:none; }
}


/* ── MODULE ACHATS SPÉCIFIQUE ── */
.pin-overlay {
  position:fixed;inset:0;background:rgba(26,24,22,.92);z-index:999;
  display:flex;align-items:center;justify-content:center;
}
.pin-box {
  background:var(--surface);border-radius:16px;padding:2.5rem;
  width:340px;text-align:center;box-shadow:0 8px 40px rgba(0,0,0,.3);
}
.pin-title {font-size:18px;font-weight:700;margin-bottom:6px;}
.pin-sub {font-size:13px;color:var(--text2);margin-bottom:1.5rem;}
.pin-dots {
  display:flex;gap:12px;justify-content:center;margin-bottom:1.5rem;
}
.pin-dot {
  width:14px;height:14px;border-radius:50%;border:2px solid var(--border2);
  transition:background .15s;
}
.pin-dot.filled {background:var(--blue);border-color:var(--blue);}
.pin-keypad {display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
.pin-key {
  padding:14px;border:1px solid var(--border);border-radius:10px;
  background:var(--surface);font-size:18px;font-weight:600;cursor:pointer;
  font-family:'DM Mono',monospace;transition:background .1s;
}
.pin-key:hover {background:var(--bg);}
.pin-key:active {background:var(--border);}
.pin-error {color:var(--red);font-size:12px;margin-top:10px;min-height:18px;}

.fourn-card {
  background:var(--surface);border:1px solid var(--border);border-radius:12px;
  overflow:hidden;margin-bottom:8px;
}
.fourn-header {
  display:flex;align-items:center;gap:12px;padding:12px 16px;cursor:pointer;
}
.fourn-header:hover {background:var(--surface2);}
.fourn-body {border-top:1px solid var(--border);padding:16px;background:var(--surface2);}
.contact-row {
  display:flex;align-items:center;gap:10px;padding:8px 0;
  border-bottom:1px solid var(--border);font-size:13px;
}
.contact-row:last-child {border-bottom:none;}

.cde-card {
  background:var(--surface);border:1px solid var(--border);border-radius:12px;
  overflow:hidden;margin-bottom:8px;
}
.cde-header {
  display:flex;align-items:center;gap:10px;padding:12px 16px;cursor:pointer;
}
.cde-header:hover {background:var(--surface2);}
.cde-body {border-top:1px solid var(--border);padding:16px;background:var(--surface2);}

.ligne-cde {
  display:grid;grid-template-columns:2fr 1fr 80px 80px 100px 100px 32px;
  gap:8px;align-items:center;padding:8px 0;
  border-bottom:1px solid var(--border);
}
.ligne-cde:last-child {border-bottom:none;}
.ligne-cde input, .ligne-cde select {
  padding:5px 8px;border:1px solid var(--border);border-radius:6px;
  font-family:inherit;font-size:12px;background:var(--surface);width:100%;
}

.status-dot {
  width:8px;height:8px;border-radius:50%;flex-shrink:0;
}
.num-cde {
  font-family:'DM Mono',monospace;font-weight:700;font-size:13px;
  color:var(--blue);
}

/* Print */
@media print {
  .no-print {display:none!important;}
  header,.app-tabs,.toolbar {display:none!important;}
  body {background:#fff;}
  .cde-print {display:block!important;}
}
.cde-print {display:none;}
</style>
</head>
<body>

<!-- PIN OVERLAY -->
<div class="pin-overlay" id="pin-overlay">
  <div class="pin-box">
    <img src="data:image/png;base64," style="height:40px;margin-bottom:1rem" alt="Rousseau"/>
    <div class="pin-title">Module Achats</div>
    <div class="pin-sub">Saisissez votre code PIN pour accéder</div>
    <div class="pin-dots" id="pin-dots">
      <div class="pin-dot" id="pd0"></div>
      <div class="pin-dot" id="pd1"></div>
      <div class="pin-dot" id="pd2"></div>
      <div class="pin-dot" id="pd3"></div>
    </div>
    <div class="pin-keypad">
      <button class="pin-key" onclick="pinKey(1)">1</button>
      <button class="pin-key" onclick="pinKey(2)">2</button>
