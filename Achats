<script>
const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwzIgJe_jVVYrwNYEgJo3NKOgL7DHZqLvAD_VO56axypAj1AOao6JcbRxIaVhwF/exec';
const PIN_HASH = '1234'; // ← MODIFIER AVANT DÉPLOIEMENT

// ═══ STATE ════════════════════════════════════════════════════════════════
let state = {
  commandes: [],
  fournisseurs: [],
  stock_mp: [],
  chantiers: [],
  articles_stock: [], // Articles du stock ERP pour liaison
};
let _ctx = {};
let _nbLignes = 0;
let _nbContacts = 0;
let _pinBuffer = '';
let _pinUnlocked = sessionStorage.getItem('achats_unlocked') === '1';

// ═══ PIN ══════════════════════════════════════════════════════════════════
function pinKey(n) {
  if (_pinBuffer.length >= 4) return;
  _pinBuffer += n;
  updatePinDots();
  if (_pinBuffer.length === 4) setTimeout(checkPin, 150);
}
function pinDel() { _pinBuffer = _pinBuffer.slice(0,-1); updatePinDots(); }
function pinClear() { _pinBuffer = ''; updatePinDots(); }
function updatePinDots() {
  for (let i=0;i<4;i++) {
    document.getElementById('pd'+i).classList.toggle('filled', i < _pinBuffer.length);
  }
};
function checkPin() {
  if (_pinBuffer === PIN_HASH) {
    sessionStorage.setItem('achats_unlocked','1');
    document.getElementById('pin-overlay').style.display = 'none';
    init();
  } else {
    document.getElementById('pin-error').textContent = 'Code incorrect — réessayez';
    _pinBuffer = '';
    updatePinDots();
    setTimeout(()=>document.getElementById('pin-error').textContent='', 2000);
  }
}

// ═══ INIT ═════════════════════════════════════════════════════════════════
async function init() {
  setSyncPill('saving','Chargement...');
  await Promise.all([loadChantiers(), loadData()]);
  populateFournSelects();
  populateChantierSelects();
  renderCdes();
  renderFourns();
  renderStock();
  renderMetrics();
  setSyncPill('ok','Synchronisé');
  document.getElementById('rt-label').textContent = 'Connecté';
}

async function loadChantiers() {
  try {
    const res = await fetch(APPS_SCRIPT_URL, {method:'POST',headers:{'Content-Type':'text/plain'},body:JSON.stringify({action:'getERP'})});
    const r = await res.json();
    if (r.ok && r.data) {
      state.chantiers = r.data.chantiers||[];
      state.articles_stock = r.data.stock||[];
    }
  } catch(e) { console.warn('loadChantiers:', e); }
}

async function loadData() {
  try {
    const res = await fetch(APPS_SCRIPT_URL, {method:'POST',headers:{'Content-Type':'text/plain'},body:JSON.stringify({action:'getAchats'})});
    const r = await res.json();
    if (r.ok) {
      state.commandes   = r.commandes   || [];
      state.fournisseurs = r.fournisseurs || [];
      state.stock_mp    = r.stock_mp    || [];
    }
  } catch(e) { console.warn('loadData:', e); }
}

async function saveData() {
  setSyncPill('saving','Enregistrement...');
  try {
    const res = await fetch(APPS_SCRIPT_URL, {method:'POST',headers:{'Content-Type':'text/plain'},
      body:JSON.stringify({action:'saveAchats',data:{commandes:state.commandes,fournisseurs:state.fournisseurs,stock_mp:state.stock_mp}})
    });
    const r = await res.json();
    if (r.ok) setSyncPill('ok','Enregistré '+new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}));
    else throw new Error(r.error);
  } catch(e) { setSyncPill('error','Erreur'); console.warn(e); }
}

// ═══ HELPERS ══════════════════════════════════════════════════════════════
function uid() { return Date.now().toString(36)+Math.random().toString(36).slice(2,5); }
function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function fmtDate(s) { if(!s)return'—';try{const[y,m,d]=s.split('-');return`${d}/${m}/${y}`}catch{return s} }
function fmtEuro(n) { return Number(n||0).toLocaleString('fr-FR',{minimumFractionDigits:2,maximumFractionDigits:2})+' €'; }
function toast(msg) { const el=document.getElementById('toast');el.textContent=msg;el.classList.add('show');setTimeout(()=>el.classList.remove('show'),2500); }
function setSyncPill(mode,text) {
  const p=document.getElementById('sync-pill');p.style.display='inline-flex';
  p.className='sync-pill'+(mode==='ok'?'':' '+mode);
  document.getElementById('sync-text').textContent=text;
}
function closeModal(id) { document.getElementById(id).classList.remove('show'); }
function showTab(id) {
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.app-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('screen-'+id).classList.add('active');
  document.getElementById('tab-'+id).classList.add('active');
}

function genNumeroCde() {
  const annee = new Date().getFullYear();
  const existing = state.commandes.filter(c=>c.num&&c.num.startsWith('CDE-'+annee+'-'));
  const nums = existing.map(c=>parseInt((c.num.split('-')[2])||0)).filter(n=>!isNaN(n));
  const next = nums.length ? Math.max(...nums)+1 : 1;
  return `CDE-${annee}-${String(next).padStart(3,'0')}`;
}

function populateFournSelects() {
  const opts = ['<option value="">— Sélectionner —</option>',
    ...state.fournisseurs.map(f=>`<option value="${f.id}">${esc(f.nom)}</option>`)
  ].join('');
  ['mc-fourn','ms-fourn'].forEach(id=>{ const el=document.getElementById(id);if(el)el.innerHTML=opts; });
}

function populateChantierSelects() {
  const opts = ['<option value="">— Sans chantier —</option>',
    ...state.chantiers.map(c=>`<option value="${c.id}">${esc(c.nom)}</option>`)
  ].join('');
  ['mc-chantier','ms-chantier'].forEach(id=>{ const el=document.getElementById(id);if(el)el.innerHTML=opts; });

  const filterOpts = ['<option value="">Tous chantiers</option>',
    ...state.chantiers.map(c=>`<option value="${c.id}">${esc(c.nom)}</option>`)
  ].join('');
  const el = document.getElementById('cde-fil-chantier');
  if(el) el.innerHTML = filterOpts;
}

function onFournChange() {
  const fournId = document.getElementById('mc-fourn').value;
  const fourn = state.fournisseurs.find(f=>f.id===fournId);
  const sel = document.getElementById('mc-contact');
  if (!fourn || !fourn.contacts?.length) {
    sel.innerHTML = '<option value="">— Aucun contact —</option>';
    return;
  }
  sel.innerHTML = ['<option value="">— Sélectionner —</option>',
    ...fourn.contacts.map((c,i)=>`<option value="${i}">${esc(c.nom)}${c.poste?' — '+c.poste:''}</option>`)
  ].join('');
}

// ═══ LIGNES DE COMMANDE ══════════════════════════════════════════════════
function addLigneCde(data={}) {
  _nbLignes++;
  const i = _nbLignes;
  const wrap = document.getElementById('lignes-cde-wrap');
  const div = document.createElement('div');
  div.id = 'ligne-'+i;
  div.style.cssText = 'display:grid;grid-template-columns:2fr 80px 80px 100px 100px 120px 32px;gap:8px;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)';

  // Articles stock disponibles pour liaison
  const stockOpts = state.articles_stock.filter(a=>a.statut==='en_stock')
    .map(a=>`<option value="${a.id}">${esc(a.designation)}</option>`).join('');

  div.innerHTML = `
    <input type="text" id="l${i}-desc" value="${esc(data.desc||'')}" placeholder="Désignation de l'article" style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-family:inherit;font-size:12px"/>
    <input type="number" id="l${i}-qte" value="${data.qte||''}" min="0" step="0.01" style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;text-align:right;font-family:'DM Mono',monospace;font-size:12px" oninput="updateLigneTotals()"/>
    <input type="text" id="l${i}-unite" value="${esc(data.unite||'')}" placeholder="u,ml…" style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-family:inherit;font-size:12px"/>
    <input type="number" id="l${i}-pu" value="${data.pu||''}" min="0" step="0.01" style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;text-align:right;font-family:'DM Mono',monospace;font-size:12px" oninput="updateLigneTotals()"/>
    <span id="l${i}-total" style="font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--blue);text-align:right">—</span>
    <div style="display:flex;align-items:center;gap:5px">
      <label style="display:flex;align-items:center;gap:4px;font-size:11px;cursor:pointer;white-space:nowrap">
        <input type="checkbox" id="l${i}-stock-chk" ${data.gerer_stock?'checked':''} onchange="toggleStockSelect(${i})" style="width:auto"/>
        📦 Stock
      </label>
    </div>
    <button onclick="removeLigne(${i})" style="border:none;background:none;cursor:pointer;color:var(--red);font-size:16px">✕</button>
    <div id="l${i}-stock-wrap" style="grid-column:1/-1;display:${data.gerer_stock?'block':'none'};padding:4px 0 2px;background:var(--blue-bg);border-radius:6px;padding:6px 10px;margin-top:2px">
      <label style="font-size:11px;color:var(--blue);font-weight:600">Article stock à lier :</label>
      <select id="l${i}-stock-art" style="margin-left:8px;padding:4px 8px;border:1px solid var(--blue-border);border-radius:6px;font-family:inherit;font-size:12px">
        <option value="">— Nouvel article —</option>
        ${stockOpts}
      </select>
      <input type="text" id="l${i}-stock-nom" value="${esc(data.stock_nom||'')}" placeholder="Nom dans le stock (si nouvel article)" style="margin-left:8px;padding:4px 8px;border:1px solid var(--blue-border);border-radius:6px;font-family:inherit;font-size:12px;width:200px"/>
    </div>`;
  wrap.appendChild(div);
  if (data.qte && data.pu) updateLigneTotals();
}

function removeLigne(i) {
  const el = document.getElementById('ligne-'+i);
  if (el) el.remove();
  updateLigneTotals();
}

function toggleStockSelect(i) {
  const chk = document.getElementById('l'+i+'-stock-chk');
  const wrap = document.getElementById('l'+i+'-stock-wrap');
  if (wrap) wrap.style.display = chk?.checked ? 'block' : 'none';
}

function updateLigneTotals() {
  let total = 0;
  for (let i=1;i<=_nbLignes;i++) {
    const qte = parseFloat(document.getElementById('l'+i+'-qte')?.value)||0;
    const pu  = parseFloat(document.getElementById('l'+i+'-pu')?.value)||0;
    const t   = qte*pu;
    const el  = document.getElementById('l'+i+'-total');
    if (el) el.textContent = t>0 ? fmtEuro(t) : '—';
    total += t;
  }
  const totEl = document.getElementById('mc-total');
  if (totEl) totEl.textContent = fmtEuro(total);
}

function getLignes() {
  const lignes = [];
  for (let i=1;i<=_nbLignes;i++) {
    const desc = document.getElementById('l'+i+'-desc')?.value?.trim();
    if (!desc) continue;
    lignes.push({
      id: uid(),
      desc,
      qte:  parseFloat(document.getElementById('l'+i+'-qte')?.value)||0,
      unite: document.getElementById('l'+i+'-unite')?.value?.trim()||'',
      pu:   parseFloat(document.getElementById('l'+i+'-pu')?.value)||0,
      total: (parseFloat(document.getElementById('l'+i+'-qte')?.value)||0) * (parseFloat(document.getElementById('l'+i+'-pu')?.value)||0),
      gerer_stock: document.getElementById('l'+i+'-stock-chk')?.checked||false,
      stock_art: document.getElementById('l'+i+'-stock-art')?.value||'',
      stock_nom: document.getElementById('l'+i+'-stock-nom')?.value?.trim()||'',
      recue: null,
    });
  }
  return lignes;
}

