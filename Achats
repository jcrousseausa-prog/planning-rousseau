    <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr 28px;gap:8px;align-items:center">
      <input type="text" id="ct${i}-nom"   value="${esc(data.nom||'')}"   placeholder="Nom prénom"  style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-family:inherit;font-size:12px"/>
      <input type="text" id="ct${i}-poste" value="${esc(data.poste||'')}" placeholder="Poste / Rôle" style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-family:inherit;font-size:12px"/>
      <input type="tel"  id="ct${i}-tel"   value="${esc(data.tel||'')}"   placeholder="Téléphone"   style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-family:inherit;font-size:12px"/>
      <input type="email" id="ct${i}-email" value="${esc(data.email||'')}" placeholder="Email"       style="padding:6px 8px;border:1px solid var(--border);border-radius:6px;font-family:inherit;font-size:12px"/>
      <button onclick="document.getElementById('contact-${i}').remove()" style="border:none;background:none;cursor:pointer;color:var(--red);font-size:16px">✕</button>
    </div>`;
  wrap.appendChild(div);
}

function getContacts() {
  const contacts = [];
  for (let i=1;i<=_nbContacts;i++) {
    const nom = document.getElementById('ct'+i+'-nom')?.value?.trim();
    if (!nom) continue;
    contacts.push({
      nom, poste: document.getElementById('ct'+i+'-poste')?.value?.trim()||'',
      tel:  document.getElementById('ct'+i+'-tel')?.value?.trim()||'',
      email:document.getElementById('ct'+i+'-email')?.value?.trim()||'',
    });
  }
  return contacts;
}

function openNewFourn() {
  _ctx = {type:'new-fourn'};
  _nbContacts = 0;
  document.getElementById('mf-title').textContent = 'Nouveau fournisseur';
  ['mf-nom','mf-siret','mf-adresse','mf-notes','mf-categorie'].forEach(id=>{
    const el=document.getElementById(id);if(el)el.value='';
  });
  document.getElementById('mf-paiement').value = 'comptant';
  document.getElementById('contacts-wrap').innerHTML = '';
  addContact();
  document.getElementById('modal-fourn').classList.add('show');
}

function openEditFourn(id) {
  const f = state.fournisseurs.find(x=>x.id===id);
  if (!f) return;
  _ctx = {type:'edit-fourn',id};
  _nbContacts = 0;
  document.getElementById('mf-title').textContent = 'Modifier — '+f.nom;
  document.getElementById('mf-nom').value = f.nom||'';
  document.getElementById('mf-siret').value = f.siret||'';
  document.getElementById('mf-adresse').value = f.adresse||'';
  document.getElementById('mf-paiement').value = f.conditions_paiement||'comptant';
  document.getElementById('mf-categorie').value = f.categorie||'';
  document.getElementById('mf-notes').value = f.notes||'';
  document.getElementById('contacts-wrap').innerHTML = '';
  (f.contacts||[]).forEach(c=>addContact(c));
  if(!(f.contacts?.length)) addContact();
  document.getElementById('modal-fourn').classList.add('show');
}

function saveFourn() {
  const nom = document.getElementById('mf-nom').value.trim();
  if (!nom) { document.getElementById('mf-nom').style.borderColor='var(--red)';return; }
  document.getElementById('mf-nom').style.borderColor='';
  const fourn = {
    id: _ctx.type==='edit-fourn' ? _ctx.id : uid(),
    nom,
    siret: document.getElementById('mf-siret').value.trim(),
    adresse: document.getElementById('mf-adresse').value.trim(),
    conditions_paiement: document.getElementById('mf-paiement').value,
    categorie: document.getElementById('mf-categorie').value.trim(),
    notes: document.getElementById('mf-notes').value.trim(),
    contacts: getContacts(),
    created_at: _ctx.type==='edit-fourn' ? (state.fournisseurs.find(f=>f.id===_ctx.id)?.created_at||new Date().toISOString()) : new Date().toISOString(),
    open: false,
  };
  if (_ctx.type==='edit-fourn') {
    const idx=state.fournisseurs.findIndex(f=>f.id===_ctx.id);
    if(idx>=0) state.fournisseurs[idx]=fourn;
  } else {
    state.fournisseurs.push(fourn);
  }
  closeModal('modal-fourn');
  populateFournSelects();
  saveData(); renderFourns(); toast('Fournisseur enregistré');
}

function deleteFourn(id) {
  if(!confirm('Supprimer ce fournisseur ?'))return;
  state.fournisseurs=state.fournisseurs.filter(f=>f.id!==id);
  saveData();renderFourns();populateFournSelects();toast('Fournisseur supprimé');
}

function renderFourns() {
  const q=(document.getElementById('fourn-search')?.value||'').toLowerCase();
  const fourns=state.fournisseurs.filter(f=>!q||f.nom.toLowerCase().includes(q)||(f.categorie||'').toLowerCase().includes(q));
  if(!fourns.length){
    document.getElementById('fourn-list').innerHTML='<div style="padding:2rem;text-align:center;color:var(--text3)">Aucun fournisseur. Cliquez sur "+ Nouveau fournisseur".</div>';return;
  }
  document.getElementById('fourn-list').innerHTML=fourns.map(f=>{
    const nbCdes=state.commandes.filter(c=>c.fourn_id===f.id).length;
    return `<div class="fourn-card">
      <div class="fourn-header" onclick="toggleFourn('${f.id}')">
        <span class="chevron${f.open?' open':''}">▶</span>
        <span style="font-weight:700;font-size:14px;flex:1">${esc(f.nom)}</span>
        ${f.categorie?`<span class="badge badge-blue">${esc(f.categorie)}</span>`:''}
        ${nbCdes?`<span class="badge badge-gray">${nbCdes} commande${nbCdes>1?'s':''}</span>`:''}
        <div onclick="event.stopPropagation()" style="display:flex;gap:5px">
          <button class="btn btn-sm" onclick="openEditFourn('${f.id}')">✎</button>
          <button class="btn btn-sm btn-red" onclick="deleteFourn('${f.id}')">✕</button>
        </div>
      </div>
      ${f.open?`<div class="fourn-body">
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:12px;font-size:12px">
          <div><div style="font-size:10px;color:var(--text3);font-weight:600;text-transform:uppercase;margin-bottom:3px">SIRET</div>${esc(f.siret||'—')}</div>
          <div><div style="font-size:10px;color:var(--text3);font-weight:600;text-transform:uppercase;margin-bottom:3px">Paiement</div>${esc(f.conditions_paiement||'—')}</div>
          <div><div style="font-size:10px;color:var(--text3);font-weight:600;text-transform:uppercase;margin-bottom:3px">Adresse</div>${esc(f.adresse||'—').replace(/\n/g,'<br>')}</div>
        </div>
        ${(f.contacts||[]).length?`<div style="font-size:11px;font-weight:700;text-transform:uppercase;color:var(--text2);margin-bottom:6px">Contacts</div>
        ${f.contacts.map(c=>`<div class="contact-row">
          <span style="font-weight:600;min-width:150px">${esc(c.nom)}</span>
          ${c.poste?`<span class="badge badge-gray" style="font-size:10px">${esc(c.poste)}</span>`:''}
          ${c.tel?`<span style="color:var(--blue)">📞 ${esc(c.tel)}</span>`:''}
          ${c.email?`<span style="color:var(--blue)">✉ ${esc(c.email)}</span>`:''}
        </div>`).join('')}`:''}
        ${f.notes?`<div style="margin-top:10px;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:8px 12px;font-size:12px;color:var(--text2)">${esc(f.notes)}</div>`:''}
      </div>`:''}</div>`;
  }).join('');
}

function toggleFourn(id){const f=state.fournisseurs.find(x=>x.id===id);if(f){f.open=!f.open;renderFourns();}}

// ═══ STOCK MP ════════════════════════════════════════════════════════════
function openNewStock() {
  _ctx={type:'new-stock'};
  ['ms-designation','ms-qte','ms-unite'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';} );
  const cdeOpts=['<option value="">—</option>',...state.commandes.filter(c=>c.statut!=='Brouillon').map(c=>`<option value="${c.num}">${esc(c.num)} — ${esc(c.fourn_nom)}</option>`)].join('');
  document.getElementById('ms-cde').innerHTML=cdeOpts;
  populateFournSelects();populateChantierSelects();
  document.getElementById('modal-stock').classList.add('show');
}

function saveStock() {
  const designation=document.getElementById('ms-designation').value.trim();
  if(!designation){document.getElementById('ms-designation').style.borderColor='var(--red)';return;}
  const fournId=document.getElementById('ms-fourn').value;
  const fourn=state.fournisseurs.find(f=>f.id===fournId);
  const chantierEl=document.getElementById('ms-chantier');
  const chantier=state.chantiers.find(c=>c.id===chantierEl.value);
  state.stock_mp.push({
    id:uid(),designation,
    qte:document.getElementById('ms-qte').value.trim(),
    unite:document.getElementById('ms-unite').value.trim(),
    fourn_id:fournId,fourn_nom:fourn?.nom||'',
    cde_num:document.getElementById('ms-cde').value,
    chantier_id:chantierEl.value,chantier_nom:chantier?.nom||'',
    statut:'en_stock',
    entree:new Date().toISOString().slice(0,10),
    created_at:new Date().toISOString()
  });
  closeModal('modal-stock');saveData();renderStock();toast('Entrée stock enregistrée');
}

function deleteStock(id){
  if(!confirm('Supprimer cette entrée ?'))return;
  state.stock_mp=state.stock_mp.filter(s=>s.id!==id);
  saveData();renderStock();
}

function renderStock(){
  const rows=state.stock_mp;
  if(!rows.length){
    document.getElementById('stock-tbody').innerHTML='<tr><td colspan="9" style="padding:2rem;text-align:center;color:var(--text3)">Aucune entrée en stock MP.</td></tr>';return;
  }
  document.getElementById('stock-tbody').innerHTML=rows.map(s=>`<tr>
    <td style="font-weight:500">${esc(s.designation)}</td>
    <td style="font-size:12px;color:var(--text2)">${esc(s.fourn_nom||'—')}</td>
    <td style="font-size:12px;color:var(--text2)">${esc(s.chantier_nom||'—')}</td>
    <td style="font-family:'DM Mono',monospace;font-size:12px">${esc(s.qte||'—')}</td>
    <td style="font-size:12px;color:var(--text3)">${esc(s.unite||'')}</td>
    <td style="font-size:11px;color:var(--text3)">${fmtDate(s.entree)}</td>
    <td style="font-size:11px">${s.cde_num?`<span class="badge badge-blue">${esc(s.cde_num)}</span>`:'—'}</td>
    <td><span class="badge ${s.statut==='en_stock'?'badge-green':'badge-gray'}">${s.statut==='en_stock'?'En stock':'Sorti'}</span></td>
    <td><button class="btn btn-sm btn-red" onclick="deleteStock('${s.id}')">✕</button></td>
  </tr>`).join('');
}

// ═══ DÉMARRAGE ════════════════════════════════════════════════════════════
if (_pinUnlocked) {
  document.getElementById('pin-overlay').style.display = 'none';
  init();
}
</script>
</body>
</html>
