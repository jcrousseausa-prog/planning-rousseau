function saveCde(statut) {
  const num = document.getElementById('mc-num').value.trim();
  const fournId = document.getElementById('mc-fourn').value;
  if (!fournId) { alert('Veuillez sélectionner un fournisseur'); return; }
  const fourn = state.fournisseurs.find(f=>f.id===fournId);
  const lignes = getLignes();
  const montant = lignes.reduce((s,l)=>s+l.total,0);
  const chantierEl = document.getElementById('mc-chantier');
  const chantier = state.chantiers.find(c=>c.id===chantierEl.value);
  const contactIdx = parseInt(document.getElementById('mc-contact').value);
  const contact = !isNaN(contactIdx) && fourn?.contacts?.[contactIdx] ? fourn.contacts[contactIdx] : null;

  const cde = {
    id: _ctx.type==='edit' ? _ctx.id : uid(),
    num,
    ref: document.getElementById('mc-ref').value.trim(),
    date: document.getElementById('mc-date').value,
    dliv: document.getElementById('mc-dliv').value,
    fourn_id: fournId,
    fourn_nom: fourn?.nom||'',
    contact_nom: contact?.nom||'',
    chantier_id: chantierEl.value,
    chantier_nom: chantier?.nom||'',
    comment: document.getElementById('mc-comment').value.trim(),
    statut, montant, lignes,
    created_at: _ctx.type==='edit' ? (state.commandes.find(c=>c.id===_ctx.id)?.created_at||new Date().toISOString()) : new Date().toISOString(),
    open: false,
  };

  if (_ctx.type==='edit') {
    const idx = state.commandes.findIndex(c=>c.id===_ctx.id);
    if (idx>=0) state.commandes[idx] = cde;
  } else {
    state.commandes.unshift(cde);
    // Créer les articles stock si nécessaire
    lignes.filter(l=>l.gerer_stock).forEach(l=>{
      const nom = l.stock_art ? null : (l.stock_nom||l.desc);
      if (!l.stock_art && nom) {
        state.stock_mp.push({
          id:uid(), designation:nom, qte:l.qte+' '+l.unite,
          unite:l.unite, fourn_id:fournId, fourn_nom:fourn?.nom||'',
          cde_num:num, chantier_id:chantierEl.value, chantier_nom:chantier?.nom||'',
          statut:'en_attente', entree:'', created_at:new Date().toISOString()
        });
      }
    });
  }

  closeModal('modal-cde');
  saveData();
  renderCdes();
  renderStock();
  renderMetrics();
  toast(statut==='Validée'?'✅ Commande validée':'💾 Brouillon enregistré');
}

function deleteCde(id) {
  if (!confirm('Supprimer cette commande ?')) return;
  state.commandes = state.commandes.filter(c=>c.id!==id);
  saveData(); renderCdes(); renderMetrics(); toast('Commande supprimée');
}

function updateStatutCde(id, statut) {
  const cde = state.commandes.find(c=>c.id===id);
  if (cde) { cde.statut=statut; saveData(); renderCdes(); renderMetrics(); toast('Statut mis à jour'); }
}

