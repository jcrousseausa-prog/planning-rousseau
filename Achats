function updateRecu(cdeId, ligneIdx, val) {
  const cde = state.commandes.find(c=>c.id===cdeId);
  if (cde?.lignes?.[ligneIdx]) {
    cde.lignes[ligneIdx].recue = parseFloat(val)||0;
    const tousRecus = cde.lignes.every(l=>l.recue>=l.qte);
    const partiel   = cde.lignes.some(l=>l.recue>0&&l.recue<l.qte);
    if(tousRecus) cde.statut='Reçue';
    else if(partiel) cde.statut='Réception partielle';
    saveData(); renderCdes(); renderMetrics();
  }
}

